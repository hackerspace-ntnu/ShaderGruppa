#version 460 core
layout(local_size_x = 16, local_size_y = 16) in;
layout(rgba8, binding = 0) uniform writeonly image2D img;
uniform float uTime;
uniform float uYaw;
uniform float uPitch;

vec4 sdBox(vec3 point, vec3 center) {
    /*
     * Beregner signert avstand fra et punkt til en boks sentrert i origo.
     * Returnerer ogsĺ overflatenormalen kodet i yzw-kanalene.
     *
     * point: punktet man mĺler avstand fra 
     * center: halvstřrrelsen pĺ boksen langs hver akse (halfSize per akse)
     *
     * Returnerer vec4:
     *   .x: signert avstand til overflaten (negativ = inni boksen)
     *   .yzw: overflatenormal rettet mot nćrmeste side, skalert med sign(point)
     */
    vec3 local = abs(point) - center;
    float closest_coord = max(local.x, max(local.y, local.z));
    vec3 outside = max(local, 0.0);
    float cube_dist = length(outside);

    vec4 f = (closest_coord > 0.0) 
        ? vec4(cube_dist, outside/cube_dist) 
        : vec4(closest_coord, local.x == closest_coord ? 1.0 : 0.0, local.y == closest_coord ? 1.0 : 0.0, local.z == closest_coord ? 1.0 : 0.0);
    
    return vec4(f.x, f.yzw * sign(point));
}
vec4 sdBoxFrame(vec3 point, vec3 center, float e)
{
    vec3 local = abs(point) - center;
    vec3 q = abs(local + e) - e;

    vec3 c1 = max(vec3(local.x, q.y, q.z), 0.0);
    vec3 c2 = max(vec3(q.x, local.y, q.z), 0.0);
    vec3 c3 = max(vec3(q.x, q.y, local.z), 0.0);

    float d1 = length(c1) + min(max(local.x, max(q.y, q.z)), 0.0);
    float d2 = length(c2) + min(max(q.x, max(local.y, q.z)), 0.0);
    float d3 = length(c3) + min(max(q.x, max(q.y, local.z)), 0.0);

    float dist = min(min(d1, d2), d3);

    vec3 normal;
    if (dist == d1)
        normal = c1 == vec3(0.0) ? vec3(sign(local.x), 0.0, 0.0) : normalize(c1) * vec3(sign(local.x), sign(q.y), sign(q.z));
    else if (dist == d2)
        normal = c2 == vec3(0.0) ? vec3(0.0, sign(local.y), 0.0) : normalize(c2) * vec3(sign(q.x), sign(local.y), sign(q.z));
    else
        normal = c3 == vec3(0.0) ? vec3(0.0, 0.0, sign(local.z)) : normalize(c3) * vec3(sign(q.x), sign(q.y), sign(local.z));

    return vec4(dist, normal);
}

vec3 cubeColor(vec3 p, vec3 cubeCenter, float halfSize) {
    /*
     * Bestemmer fargen pĺ en side av kuben basert pĺ hitpunktets posisjon.
     * Hver av de 6 sidene fĺr en unik farge.
     *
     * p: hitpunktet pĺ kubens overflate 
     * cubeCenter: kubens senterpunkt
     * halfSize: halvparten av kubens sidelengde
     *
     * Returnerer vec3: RGB-farge for den trufne siden
     */
    vec3 local = p - cubeCenter;
    vec3 absL  = abs(local);
    float eps  = 0.001;
    if (absL.x > halfSize - eps)
        return local.x > 0.0 ? vec3(1,0,0) : vec3(0,0.5,0.5);
    else if (absL.y > halfSize - eps)
        return local.y > 0.0 ? vec3(0,1,0) : vec3(1,1,0);
    else
        return local.z > 0.0 ? vec3(0,0,1) : vec3(1,0.5,0);
}

// Skal brukes senere
vec3 calcNormal(vec3 p) {
    /*
     * Beregner overflatenormalen i et hitpunkt via finite differences.
     * Sampler SDF-en i smĺ forskyvninger langs hver akse og beregner gradienten.
     *
     * p: hitpunktet pĺ overflaten
     *
     * Returnerer vec3: normalisert overflatenormal i hitpunktet
     */
    float eps = 0.001;
    return normalize(vec3(
        sdBox(p + vec3(eps, 0, 0), vec3(0.5)).x - sdBox(p - vec3(eps, 0, 0), vec3(0.5)).x,
        sdBox(p + vec3(0, eps, 0), vec3(0.5)).x - sdBox(p - vec3(0, eps, 0), vec3(0.5)).x,
        sdBox(p + vec3(0, 0, eps), vec3(0.5)).x - sdBox(p - vec3(0, 0, eps), vec3(0.5)).x
    ));
}

float rayMarch(vec3 ro, vec3 rd) {
    /*
     * Sender en ray inn i scenen og finner nćrmeste treffpunkt med kuben.
     * Bruker sphere marching: gĺr fremover med steglengde lik SDF-verdien.
     *
     * ro: ray origin, startpunktet til strĺlen
     * rd: ray direction, normalisert retningsvektor
     *
     * Returnerer float:
     *   t: avstand langs strĺlen til treffpunktet
     *   -1.0: ingen treff (maks iterasjoner eller utenfor rekkevidde)
     */
    float t = 0.0;
    for (int i = 0; i < 64; i++) {
        float d = sdBoxFrame(ro + rd * t, vec3(0.5),0.05).x;
        if (d < 0.001) return t;
        t += d;
        if (t > 20.0) break;
    }
    return -1.0;
}

mat3 rotY(float a) {
    /*
     * Rotasjonsmatrise rundt Y-aksen (yaw).
     *
     * a: vinkel i radianer
     *
     * Returnerer mat3: rotasjonsmatrise for rotasjon rundt Y-aksen
     */
    float c = cos(a), s = sin(a);
    return mat3( c, 0.0, s,
                0.0, 1.0, 0.0,
                -s, 0.0, c);
}

mat3 rotX(float a) {
    /*
     * Rotasjonsmatrise rundt X-aksen (pitch).
     *
     * a: vinkel i radianer
     *
     * Returnerer mat3: rotasjonsmatrise for rotasjon rundt X-aksen
     */
    float c = cos(a), s = sin(a);
    return mat3(1.0, 0.0, 0.0,
                0.0,  c,  -s,
                0.0,  s,   c);
}

void main() {

    ivec2 pix  = ivec2(gl_GlobalInvocationID.xy);
    ivec2 size = imageSize(img);
    if (pix.x >= size.x || pix.y >= size.y) return;

    // UV-koordinater sentrert rundt origo, normalisert mot hřyde 
    vec2 uv = (vec2(pix) - 0.5 * vec2(size)) / float(size.y);

    // Bygg kameramatrise fra mus-input og plasser kamera 3 enheter bak
    mat3 cam = rotX(uPitch) * rotY(uYaw);
    vec3 ro = cam * vec3(0.0, 0.0, -3.0);
    vec3 rd = cam * normalize(vec3(uv, 1.0));

    float t = rayMarch(ro, rd);
    vec3 fragColor = vec3(0.05); // bakgrunn

    if (t > 0.0) {
        vec3 point = ro + rd * t;
        fragColor = vec3(1,1,1);
        fragColor = cubeColor(point, vec3(0.0), 0.5);
        /*vec3 normal = calcNormal(point);*/
        /*float diffuse = max(dot(normal, normalize(vec3(1,1,1))), 0.0);*/
        /*fragColor = fragColor * (0.2 + diffuse);*/
    }

    imageStore(img, pix, vec4(fragColor, 1.0));
}